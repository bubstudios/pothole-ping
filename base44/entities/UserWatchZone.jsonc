{
  "name": "UserWatchZone",
  "type": "object",
  "properties": {
    "watch_zone_id": {
      "type": "string",
      "description": "The watch zone being subscribed to"
    }
  },
  "required": [
    "watch_zone_id"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "user"
      }
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}